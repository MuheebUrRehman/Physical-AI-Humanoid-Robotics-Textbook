# API Keys — copy this file to .env and fill in your values
# The backend uses these in priority order:
# LLM_API_KEY → OPENROUTER_API_KEY → GEMINI_API_KEY

COHERE_API_KEY=
COHERE_MODEL=embed-multilingual-v3.0
QDRANT_API_KEY=
QDRANT_HOST=localhost

# Primary LLM key (OpenRouter recommended)
LLM_API_KEY=
# Fallback options (optional)
GEMINI_API_KEY=

# Optional overrides
LLM_MODEL=
LLM_BASE_URL=
LLM_SITE_URL=https://physical-ai-humanoid-robotics-textb-three-alpha.vercel.app
LLM_APP_NAME=Physical AI Textbook
ALLOWED_ORIGINS=http://localhost:3000
TOP_K=3
RELEVANCE_THRESHOLD=0.0
STREAMING_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Backend
PORT=8000
