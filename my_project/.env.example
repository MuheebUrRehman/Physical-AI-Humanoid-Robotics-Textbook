# API Keys — copy this file to .env and fill in your values
# The backend uses these in priority order:
# LLM_API_KEY → OPENROUTER_API_KEY → GEMINI_API_KEY

COHERE_API_KEY=
QDRANT_API_KEY=
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333

# Primary LLM key (OpenRouter recommended)
LLM_API_KEY=
# Fallback options (optional)
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Optional overrides
LLM_MODEL=
LLM_BASE_URL=
ALLOWED_ORIGINS=http://localhost:3000

# Backend
PORT=8000
